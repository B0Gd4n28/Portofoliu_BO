{
  "name": "portofoliu-bogdan-ob",
  "version": "2.0.0",
  "description": "Full-Stack Developer Portfolio & Lead Generation Website — Obreja Bogdan",
  "author": "Obreja Bogdan <bogdanob28@gmail.com>",
  "license": "MIT",
  "homepage": "https://bogdanob.info",
  "repository": {
    "type": "git",
    "url": "https://github.com/B0Gd4n28/Portofoliu_BO.git"
  },
  "keywords": [
    "portfolio",
    "web-developer",
    "full-stack",
    "lead-generation",
    "tailwindcss"
  ],
  "scripts": {
    "start": "npx serve .",
    "lint": "npx htmlhint *.html",
    "build:tw": "npx tailwindcss -i input.css -o css/tailwind.min.css --minify",
    "build:css": "npx cleancss -o css/style.min.css css/style.css",
    "build:js": "npx terser js/main.js -o js/main.min.js --compress --mangle",
    "build": "npm run build:tw && npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0"
  }
}
